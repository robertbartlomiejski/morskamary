{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://morskamary.local/schemas/reliability_metrics.schema.json",
  "title": "Reliability metrics row",
  "type": "object",
  "required": [
    "reliability_pk",
    "run_pk",
    "code_family_code",
    "code_family_label",
    "metric_code",
    "metric_label",
    "sample_type_code",
    "sample_type_label",
    "metric_value",
    "threshold_value",
    "status_code",
    "status_label"
  ],
  "additionalProperties": false,
  "properties": {
    "reliability_pk": { "type": "string", "minLength": 1 },
    "run_pk": { "type": "string", "minLength": 1 },
    "code_family_code": {
      "type": "integer",
      "enum": [1, 2, 3, 4, 5, -99, -98, -97, -96, -95],
      "x-categorical": true,
      "x-label-field": "code_family_label",
      "x-value-labels": {
        "1": "sector",
        "2": "qmbd_axis",
        "3": "provider_source_type",
        "4": "gap_type",
        "5": "review_status",
        "-99": "Unknown",
        "-98": "Not extracted",
        "-97": "Not applicable",
        "-96": "Restricted",
        "-95": "Validation error"
      },
      "x-missing-codes": [-99, -98, -97, -96, -95],
      "x-measurement-level": "nominal",
      "x-allowed-values": [1, 2, 3, 4, 5, -99, -98, -97, -96, -95]
    },
    "code_family_label": { "type": "string", "minLength": 1 },
    "metric_code": {
      "type": "integer",
      "enum": [1, 2, 3, 4, 5, 6, -99, -98, -97, -96, -95],
      "x-categorical": true,
      "x-label-field": "metric_label",
      "x-value-labels": {
        "1": "cohen_kappa",
        "2": "krippendorff_alpha",
        "3": "precision",
        "4": "recall",
        "5": "f1",
        "6": "percent_agreement",
        "-99": "Unknown",
        "-98": "Not extracted",
        "-97": "Not applicable",
        "-96": "Restricted",
        "-95": "Validation error"
      },
      "x-missing-codes": [-99, -98, -97, -96, -95],
      "x-measurement-level": "nominal",
      "x-allowed-values": [1, 2, 3, 4, 5, 6, -99, -98, -97, -96, -95]
    },
    "metric_label": { "type": "string", "minLength": 1 },
    "sample_type_code": {
      "type": "integer",
      "enum": [1, 2, 3, -99, -98, -97, -96, -95],
      "x-categorical": true,
      "x-label-field": "sample_type_label",
      "x-value-labels": {
        "1": "human_validation_sample",
        "2": "machine_human_comparison",
        "3": "full_run_metric",
        "-99": "Unknown",
        "-98": "Not extracted",
        "-97": "Not applicable",
        "-96": "Restricted",
        "-95": "Validation error"
      },
      "x-missing-codes": [-99, -98, -97, -96, -95],
      "x-measurement-level": "nominal",
      "x-allowed-values": [1, 2, 3, -99, -98, -97, -96, -95]
    },
    "sample_type_label": { "type": "string", "minLength": 1 },
    "metric_value": { "type": "number" },
    "threshold_value": { "type": "number" },
    "status_code": {
      "type": "integer",
      "enum": [1, 2, 3, -99, -98, -97, -96, -95],
      "x-categorical": true,
      "x-label-field": "status_label",
      "x-value-labels": {
        "1": "pass",
        "2": "warning",
        "3": "fail",
        "-99": "Unknown",
        "-98": "Not extracted",
        "-97": "Not applicable",
        "-96": "Restricted",
        "-95": "Validation error"
      },
      "x-missing-codes": [-99, -98, -97, -96, -95],
      "x-measurement-level": "nominal",
      "x-allowed-values": [1, 2, 3, -99, -98, -97, -96, -95]
    },
    "status_label": { "type": "string", "minLength": 1 }
  }
}
